# Environment Configuration
ENVIRONMENT="local"
LOG_LEVEL="DEBUG"

# Change these values if you deploy the backend and frontend
# on any hosting provider with some DNS. Please ensure to 
# provide the URL with scheme like http or https
BACKEND_API_ENDPOINT="http://localhost:8000"
UI_APP_URL="http://localhost:3000"

# Database Configuration
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/postgres"
REDIS_URL="redis://:redissecret@localhost:6379"

# Managed single-organization mode.
# Keep this enabled for deployments where one business operates one voice-agent
# estate and customer accounts should not create their own tenants on signup.
ALLOW_PUBLIC_SIGNUP=false
SINGLE_ORGANIZATION_MODE=true
MANAGED_ORGANIZATION_PROVIDER_ID="managed_single_org"

# AWS S3 Configuration
ENABLE_AWS_S3="false"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_BUCKET=""
# S3_REGION=""

# MinIO Configuration if using containerised MinIO instead of
# AWS S3
MINIO_ENDPOINT=localhost:9000
# Full URL (with scheme) that browsers use to reach MinIO. Required.
# Remote deployments behind HTTPS: set to e.g. https://your-server.example.com
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=voice-audio
MINIO_SECURE=false

# Tracing and Analytics using Langfuse
# Credentials can be set here or per-organization via the UI at /settings.
# Tracing is automatically active when credentials are available.
# LANGFUSE_SECRET_KEY="sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# LANGFUSE_PUBLIC_KEY="pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# LANGFUSE_HOST="https://cloud.langfuse.com"

# TURN Server Configuration (for WebRTC NAT traversal)
# Required for reliable WebRTC connections behind firewalls/NAT
# Uses time-limited credentials (TURN REST API) for security
TURN_HOST=localhost
TURN_SECRET=spx-voice-turn-secret-change-in-production
# TURN_PORT=3478  # Default: 3478
# TURN_TLS_PORT=5349  # Default: 5349
# TURN_CREDENTIAL_TTL=86400  # Default: 24 hours in seconds

# Voice Runtime
# LiveKit is the OSS runtime.
VOICE_RUNTIME=livekit
# LIVEKIT_URL=wss://livekit.example.com
# LIVEKIT_CLIENT_URL=wss://livekit.example.com
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_AGENT_NAME=spx-voice
# LIVEKIT_ROOM_PREFIX=spx-voice
# LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# LIVEKIT_SIP_DEFAULT_FROM_NUMBER=
# Public SIP host/URI for inbound calls into LiveKit SIP. Vobiz gets this
# value as inbound_destination, with any sip: prefix stripped.
# LIVEKIT_SIP_INBOUND_HOST=your-sip-host.example.com
# For local Docker dev, lets the API start/stop the LiveKit worker after
# settings are saved through the UI.
# LIVEKIT_WORKER_MANAGED_BY_API=true

# Optional post-call tracking and LiveKit egress recording.
# SPX_VOICE_POST_CALL_WEBHOOK_URL=
# SPX_VOICE_RECORDINGS_S3_ENDPOINT_URL=
# SPX_VOICE_RECORDINGS_S3_BUCKET=
# SPX_VOICE_RECORDINGS_S3_ACCESS_KEY_ID=
# SPX_VOICE_RECORDINGS_S3_SECRET_ACCESS_KEY=
# SPX_VOICE_RECORDINGS_S3_REGION=us-east-1
# SPX_VOICE_RECORDINGS_S3_FORCE_PATH_STYLE=false
# SPX_VOICE_RECORDINGS_PUBLIC_BASE_URL=
# SPX_VOICE_RECORDINGS_KEY_PREFIX=SPX-VOICE-INBOUND
